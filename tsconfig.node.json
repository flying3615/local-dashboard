{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node", "@cloudflare/workers-types"]
  },
  "include": ["vite.config.ts", "server/**/*.ts", "worker/**/*.ts", "scripts/**/*.ts"],
  "exclude": ["**/*.test.ts"]
}
